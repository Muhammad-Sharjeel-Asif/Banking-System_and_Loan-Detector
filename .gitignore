# ─────────────────────────────────────────────────────────────────────────────
# Project Specific - Banking System
# ─────────────────────────────────────────────────────────────────────────────

# Data files (user data, transactions - should not be committed)
backend/data/*.csv
backend/data/statements/*.csv

# Keep .gitkeep for folder structure
!backend/data/.gitkeep
!backend/data/statements/.gitkeep

# ML datasets (Kaggle downloads - too large for Git)
backend/ml/loan_data.csv
backend/ml/creditcard.csv
backend/ml/loan-train.csv
backend/ml/loan-test.csv

